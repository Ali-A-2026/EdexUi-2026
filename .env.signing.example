# Copy this file to `.env.signing.local` and fill in real values when you have
# a trusted signing certificate. Do not commit the filled file.

# Windows / generic electron-builder signing
CSC_LINK=/absolute/path/to/your/certificate.p12
CSC_KEY_PASSWORD=your_certificate_password

# Optional Windows identity override
# CSC_NAME=Your Company Name

# macOS signing and notarization
APPLE_ID=your-apple-id@example.com
APPLE_APP_SPECIFIC_PASSWORD=your-app-specific-password
APPLE_TEAM_ID=YOURTEAMID
