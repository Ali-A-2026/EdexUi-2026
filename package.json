{
  "name": "edexui-2026",
  "productName": "EdexUi-2026",
  "version": "2026.1.1",
  "description": "EdexUi-2026 is a maintained, open-source continuation of the original eDEX-UI experience.",
  "keywords": [
    "desktop",
    "sci-fi",
    "gui",
    "portable",
    "tty",
    "terminal"
  ],
  "main": "src/_boot.js",
  "scripts": {
  "start": "electron src",

  "install": "npm install && cd src && npm install --legacy-peer-deps && cd ..",

  "rebuild": "npx electron-rebuild -f -w node-pty",

  "prebuild": "rm -rf prebuild-src && mkdir -p prebuild-src && cp -r src/* prebuild-src/ && node prebuild-minify.js && cd prebuild-src && npm install --legacy-peer-deps && cd ..",

  "build": "npm run rebuild && ./node_modules/.bin/electron-builder build",

  "postbuild": "rm -rf prebuild-src"
},
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ali-A-2026/EdexUi-2026.git"
  },
  "author": {
    "name": "Ali-A-Alwahed",
    "email": "ali.a.alwahed@users.noreply.github.com"
  },
  "contributors": [
    "Gabriel \"Squared\" Saillard (original creator of eDEX-UI)",
    "Hyder6112 (special thanks)",
    "Ahmed Adnan (special thanks)"
  ],
  "license": "GPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/Ali-A-2026/EdexUi-2026/issues"
  },
  "homepage": "https://github.com/Ali-A-2026/EdexUi-2026#readme",
  "build": {
    "appId": "com.edexui2026.app",
    "productName": "EdexUi-2026",
    "publish": "github",
    "asar": true,
    "compression": "normal",
    "copyright": "Copyright © 2026 Ali-A-Alwahed. Based on the original eDEX-UI by Gabriel Squared Saillard and upstream contributors. Special thanks to Hyder6112 and Ahmed Adnan.",
    "directories": {
      "output": "dist",
      "app": "prebuild-src"
    },
    "forceCodeSigning": false,
    "npmRebuild": true,
    "artifactName": "EdexUi-2026-${os}-${arch}.${ext}",
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "maintainer": "Ali-A-Alwahed <ali.a.alwahed@users.noreply.github.com>",
      "category": "System",
      "icon": "media/linuxIcons"
    },
    "rpm": {
      "fpm": [
        "--rpm-compression",
        "gzip"
      ]
    },
    "appImage": {
      "artifactName": "EdexUi-2026-Linux-${arch}.AppImage"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "public.app-category.utilities",
      "icon": "media/icon.icns"
    },
    "dmg": {
      "artifactName": "EdexUi-2026-macOS-${arch}.dmg"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "icon": "media/icon.ico"
    },
    "nsis": {
      "artifactName": "EdexUi-2026-Windows-${arch}.exe",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true
    }
  },
  "dependencies": {
    "@electron/rebuild": "^4.0.3",
    "clean-css": "5.2.1",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "mime-types": "^2.1.33",
    "node-abi": "2.30.1",
    "node-json-minify": "1.0.0",
    "signale": "^1.4.0",
    "terser": "^5.9.0"
  },
  "optionalDependencies": {
    "cson-parser": "4.0.9",
    "dmg-license": "^1.0.11"
  }
}
